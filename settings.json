      "payment_reminder": {
        "label": "Payment reminder",
        "subject": "Payment reminder – {{ client_name }} – {{ event_date }}",
        "body": "<div data-im-format-wrap=\"1\" style=\"font-family: Tahoma, Geneva, sans-serif; font-size: 10pt;\"><p style=\"margin:0 0 12px 0;\">Hi {{ client_first_name }},<br></p><p style=\"margin:0 0 12px 0;\">Just a quick reminder about the remaining balance of {{ balance_amount }} <span style=\"font-size: 0.875rem; font-family: inherit; background-color: rgba(255,255,255,var(--tw-bg-opacity));\">for AhMen's performance on </span>{{ event_date }}<span style=\"font-size: 0.875rem; font-family: inherit; background-color: rgba(255,255,255,var(--tw-bg-opacity));\">. The due date is </span>{{ balance_due_date }}<span style=\"font-size: 0.875rem; font-family: inherit; background-color: rgba(255,255,255,var(--tw-bg-opacity));\">.</span></p><p style=\"margin:0 0 12px 0;\">If you've already sent payment, please ignore this.</p><p style=\"margin:0 0 12px 0;\">Thanks so much,</p><p style=\"margin:0 0 12px 0;\">Motti</p></div>"
      },
      "thank_you": {
        "subject": "Thank you – {{ client_name }} – {{ event_date }}",
