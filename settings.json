        "subject": "Balance invoice – {{ client_name }} – {{ event_date }}",
        "body": "<div data-im-format-wrap=\"1\" style=\"font-family: Tahoma, Geneva, sans-serif; font-size: 10pt;\"><p style=\"margin:0 0 12px 0;\">Hi {{ client_first_name }},</p><p style=\"margin:0 0 12px 0;\"><span style=\"font-size: 0.875rem; background-color: rgba(255,255,255,var(--tw-bg-opacity)); font-family: inherit;\">Please find your balance invoice attached. The due date is </span>{{ balance_due_date }}<span style=\"font-size: 0.875rem; background-color: rgba(255,255,255,var(--tw-bg-opacity)); font-family: inherit;\">.</span><br></p><p style=\"margin:0 0 12px 0;\"><span style=\"font-size: 10pt; background-color: rgba(255,255,255,var(--tw-bg-opacity));\">Thanks so much,</span><br></p><p style=\"margin:0 0 12px 0;\"><span style=\"font-size: 10pt; background-color: rgba(255,255,255,var(--tw-bg-opacity));\">Motti</span></p></div>"
