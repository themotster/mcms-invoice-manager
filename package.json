{
  "name": "invoice-master-dashboard",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "electron .",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "start:electron": "wait-on renderer/bundle.js && electronmon .",
    "dev": "npm run build:dev && concurrently \"npm:watch\" \"npm:start:electron\"",
    "build:mcms": "webpack --config mcms/webpack.config.js --mode production",
    "build:mcms:dev": "webpack --config mcms/webpack.config.js --mode development",
    "mcms:watch": "webpack --config mcms/webpack.config.js --mode development --watch",
    "mcms:start:electron": "APP_MODE=mcms electron .",
    "mcms:dev": "npm run build:mcms:dev && concurrently \"npm:mcms:watch\" \"npm:mcms:start:electron\"",
    "pack:mcms": "npm run build:mcms && electron-packager . 'MCMS Invoice Manager' --platform=darwin --arch=$(node -p \"process.arch\") --out=release --overwrite",
    "open:mcms": "open -n \"./release/MCMS Invoice Manager-darwin-*/MCMS Invoice Manager.app\"",
    "pack:mac": "npm run build && electron-packager . 'AhMen Booking Manager' --platform=darwin --arch=$(node -p \"process.arch\") --out=release --overwrite",
    "open:mac": "open -n \"./release/AhMen Booking Manager-darwin-*/AhMen Booking Manager.app\"",
    "migrate:import-jobsheets": "node scripts/import_jobsheets.js --dry-run",
    "test": "jest"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.3",
    "docx": "^8.5.0",
    "electron": "^28.0.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.2.1",
    "electron-packager": "^17.1.2",
    "electronmon": "^2.0.3",
    "jest": "^29.7.0",
    "tailwindcss": "^3.4.0",
    "wait-on": "^9.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
