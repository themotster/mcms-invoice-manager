{
  "name": "mcms-invoice-manager",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "webpack --config mcms/webpack.config.js --mode production",
    "build:dev": "webpack --config mcms/webpack.config.js --mode development",
    "watch": "webpack --config mcms/webpack.config.js --mode development --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build:dev && concurrently \"npm:watch\" \"electronmon .\"",
    "mcms:dev": "npm run dev",
    "open:mcms:dev": "npm run dev",
    "pack:mcms": "npm run build && electron-packager . 'MCMS Invoice Manager' --platform=darwin --arch=$(node -p \"process.arch\") --out=release --icon=icons/mcms.icns --overwrite",
    "open:mcms": "open -n ./release/MCMS\\ Invoice\\ Manager-darwin-*/MCMS\\ Invoice\\ Manager.app",
    "clean:release": "rm -rf release/*",
    "pack:mcms:clean": "npm run clean:release && npm run pack:mcms",
    "test": "jest",
    "test:e2e:mcms": "jest __tests__/e2e-mcms-invoice.test.js"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.3",
    "electron": "^28.0.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "chokidar": "^3.5.3",
    "concurrently": "^9.2.1",
    "electron-packager": "^17.1.2",
    "electronmon": "^2.0.3",
    "jest": "^29.7.0",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
